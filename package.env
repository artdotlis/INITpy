COPYRIGHT="Artur Lissin"

PYV=3.13
UV_CACHE_DIR=.uv/cache
UV_INSTALL_DIR=.uv/bin
UV_PYTHON_INSTALL_DIR=.uv/python
UV_PYTHON_BIN_DIR=.uv/python/bin
UV_TOOL_DIR=.uv/tools
UV_TOOL_BIN_DIR=.uv/tools/bin
UV_NO_MODIFY_PATH=1

CONFIG_SHELL=configs/lint/shellcheckrc

BIN_RUN_ENV_LINT=bin/lint/lint_env.sh
BIN_RUN_LICENSE_LINT=bin/lint/licenses.sh
BIN_RUN_LFS_LINT=bin/lint/lfs_files.sh

PKG=packages
PKG1_ENV=packages/pkg1/.env

# Configuration which are required for docker compose and should be copied to ROOT/.env
BIN_DEPLOY_PREP=bin/deploy/prep.sh
BIN_DEPLOY_REQ=bin/deploy/req.sh
